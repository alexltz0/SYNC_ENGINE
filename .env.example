# Sync Engine Configuration
NODE_ENV=development
PORT=8080
HOST=0.0.0.0

# Cluster
CLUSTER_NODE_ID=node-1
CLUSTER_REGION=us-east-1
CLUSTER_ZONE=us-east-1a
CLUSTER_ADVERTISE_HOST=localhost
CLUSTER_ADVERTISE_PORT=8080
CLUSTER_SEEDS=localhost:8080

# WebSocket
WS_PORT=9090
WS_MAX_CONNECTIONS=10000
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_PAYLOAD_SIZE=65536

# Redis (optional - for multi-node coordination)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=sync:

# Persistence
DB_PATH=./data/sync_engine.db
WAL_PATH=./data/wal
SNAPSHOT_PATH=./data/snapshots
SNAPSHOT_INTERVAL=300000

# Security
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRATION=86400
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9100
LOG_LEVEL=info
LOG_FORMAT=json

# Game Server Orchestration
MAX_GAME_SERVERS=1000
DEFAULT_TICK_RATE=64
MAX_PLAYERS_PER_SERVER=100
MATCHMAKING_INTERVAL=5000
SERVER_TIMEOUT=60000
