{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": "./src",
    "paths": {
      "@core/*": ["core/*"],
      "@network/*": ["network/*"],
      "@cluster/*": ["cluster/*"],
      "@sync/*": ["sync/*"],
      "@persistence/*": ["persistence/*"],
      "@monitoring/*": ["monitoring/*"],
      "@security/*": ["security/*"],
      "@api/*": ["api/*"],
      "@orchestration/*": ["orchestration/*"],
      "@config/*": ["config/*"],
      "@utils/*": ["utils/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "dashboard", "**/*.test.ts"]
}
